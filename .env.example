# Copy this file to .env and edit if needed.

# LM Studio local server URL. Default port is usually 1234.
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# LM Studio accepts any non-empty API key value for local OpenAI-compatible use.
LMSTUDIO_API_KEY=lm-studio

# Optional. Leave empty to auto-select the first loaded/available model from LM Studio.
# You can also paste the exact model id shown in LM Studio.
LMSTUDIO_MODEL=

# Model behavior settings.
LMSTUDIO_TEMPERATURE=0.5
LMSTUDIO_MAX_TOKENS=300

# Conversation memory size in message pairs.
AGENT_MEMORY_TURNS=6
